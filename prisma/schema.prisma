generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InventoryItem {
  id                Int      @id @default(autoincrement())
  name              String
  category          String
  quantity          Float
  unit              String
  lowStockThreshold Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
