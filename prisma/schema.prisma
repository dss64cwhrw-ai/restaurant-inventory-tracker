generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InventoryItem {
  id                Int      @id @default(autoincrement())
  userId            String   @default("")
  name              String
  category          String
  quantity          Float
  unit              String
  lowStockThreshold Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model PrepTask {
  id        Int      @id @default(autoincrement())
  userId    String   @default("")
  title     String
  station   String
  dueTime   DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
